# LLM Provider Keys
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Database
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=inference_logs

# Redis
REDIS_URL=redis://redis:6379/0

# App
APP_ENV=development

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://frontend:3000

# SDK / pipeline defaults (all optional — shown with built-in defaults)
DEFAULT_MODEL=gemini-2.5-flash
DEFAULT_PROVIDER=gemini
DEFAULT_OPENAI_MODEL=gpt-4.1
PREVIEW_MAX_LENGTH=500
REDIS_QUEUE_KEY=inference_logs
MAX_CONTEXT_MESSAGES=20

# Serverless / Vercel deployment
# When deploying to Vercel, override these environment variables in the Vercel dashboard:
#   SERVERLESS_MODE=true
#   BACKGROUND_WORKER_ENABLED=false
#   DATABASE_URL=<neon-postgres-connection-string>
#   REDIS_URL=<upstash-redis-url>
#   CRON_SECRET=<auto-set-by-vercel-or-generate-a-secret>
SERVERLESS_MODE=false
BACKGROUND_WORKER_ENABLED=true
CRON_SECRET=

# Host port mappings — change if default ports are already in use on your machine
# Defaults: BACKEND=8000, FRONTEND=3000, POSTGRES=5432, REDIS=6379, NGINX=80
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
NGINX_PORT=80
